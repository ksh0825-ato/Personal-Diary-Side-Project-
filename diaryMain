							 mm.setRowCount(0);
							 for (Object[] rw : rr)
								 mm.addRow(rw);
							 
							 par.refreshCalendar();
							 par.refreshDiaryList();
							 par.refreshDoneList();
							 JOptionPane.showMessageDialog(null, "일기가 정상적으로 삭제되었습니다.");
							 dispose();
						 } // if문 끝
					 }); // delB.addActionListener 끝
					 
					 dAb.addActionListener(e -> {
						    String t = dnF.getText().trim();
						    if (t.isEmpty()) {
						        JOptionPane.showMessageDialog(this, "추가할 한 일 내용을 입력하세요.");
						        return;
						    } // if문 끝
						    
						    // 1. 중복 검사만 수행
						    for (int i = 0; i < fdM.getRowCount(); i++) {
						        if (dDate.equals(fdM.getValueAt(i, 1)) && t.equals(fdM.getValueAt(i, 2))) {
						            JOptionPane.showMessageDialog(this, "[" + dDate + "] 날짜에 동일한 항목이 존재합니다.", "중복 입력 경고", 2);
						            return; // 중복이 발견되면 여기서 곧바로 실행 중단!
						        } // if문 끝
						    } // for문 끝
						    
						    // 2. 반복문을 무사히 통과했다면 (중복이 없다면) 항목 추가
						    fdM.addRow(new Object[] { false, dDate, t });
						    dnF.setText("");
						}); // dAb.addActionListener 끝
					 
					 dDb.addActionListener(e -> {
						 int sr = fdT.getSelectedRow();
						 if (sr == -1)
							 JOptionPane.showMessageDialog(this, "삭제할 Done-list 행을 선택해주세요.");
						 else
							 fdM.removeRow(sr);
					 }); // dDb.addActionListener 끝
					 
					 sB.addActionListener(e -> {
						 System.out.println("디버깅 - 현재 저장하려는 유저 ID: " + usr.getUserId());
						 String t = tF.getText().trim(), c = cA.getText().trim(), rt = dnF.getText().trim();
						 dao.deleteDoneByDate(dDate, usr.getUserId());
						 
						 if (t.isEmpty() || c.isEmpty()) {
							 JOptionPane.showMessageDialog(this, "일기 제목과 본문을 모두 입력해 주세요.", "입력 오류", 2);
							 return;
						 } // if문 끝
						 if (!rt.isEmpty() && JOptionPane.showConfirmDialog(this, "저장하지 않은 done-list는 사라집니다, 괜찮으시겠습니까?",
								 "Done-list 추가 누락 안내", 0, 2) != 0)
							 return;
						 int mi = mCb.getSelectedIndex();
						 if (ed == null) {
							 DiaryVO nd = new DiaryVO();
							 nd.setUserId(usr.getUserId());
							 nd.setUserName(usr.getUsername());
							 nd.setTitle(t);
							 nd.setContent(c);
							 nd.setDiaryDate(dDate);
							 nd.setMoodId(mi);
							 dao.insertDiary(nd);
						 } else {
							 exDiary.setTitle(t);
							 exDiary.setContent(c);
							 exDiary.setMoodId(mi);
							 // 여기서 현재 시간을 생성하여 exDiary에 넣어주어야 합니다.
							 String now = java.time.LocalDateTime.now()
									 .format(java.time.format.DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
							 exDiary.setUpdatedAt(now);
							 dao.updateDiary(exDiary); // 이제 DAO가 이 객체를 저장할 때 시간도 포함합니다.
							 System.out.println(now);
						 } // if-else문 끝
						 DefaultTableModel mm = par.getDoneModel();
						 List<Object[]> sr = new ArrayList<>();
						 for (int i = 0; i < mm.getRowCount(); i++)
							 if (!dDate.equals(mm.getValueAt(i, 1)) && !"-".equals(mm.getValueAt(i, 1)))
								 sr.add(new Object[] { mm.getValueAt(i, 0), mm.getValueAt(i, 1), mm.getValueAt(i, 2), "수정",
								 "삭제" });
						 
						 for (int i = 0; i < fdM.getRowCount(); i++) {
							 DoneVO vo = new DoneVO();
							 vo.setUserId(usr.getUserId());
							 vo.setDoneDate((String) fdM.getValueAt(i, 1));
							 vo.setContent((String) fdM.getValueAt(i, 2));
							 vo.setDone((Boolean) fdM.getValueAt(i, 0));
							 dao.insertDone(vo);
						 } // for문 끝
						 
						 sr.sort((r1, r2) -> ((String) r1[1]).compareTo((String) r2[1]));
						 mm.setRowCount(0);
						 for (Object[] rw : sr)
							 mm.addRow(rw);
						 par.loadDoneListFromDB();
						 par.refreshDoneListUI();
						 par.refreshCalendar();
						 par.refreshDiaryList();
						 dispose();
					 }); // sB.addActionListener 끝
		}; // public DiaryFormDialog 끝
	} // public static class DiaryFormDialog 끝
