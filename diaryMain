	// DB에서 데이터를 가져와 doneTable(JTable) 모델에 채우는 메서드
	public void loadDoneListFromDB() {
		// 1. DB에서 리스트 가져오기
		List<DoneVO> list = diaryDAO.getDoneList(currentUser.getUserId());

		// 2. 현재 화면의 모델(doneModel) 비우기
		doneModel.setRowCount(0);

		// 3. DB 데이터를 테이블에 한 줄씩 다시 추가
		for (DoneVO vo : list) {
			doneModel.addRow(new Object[] { vo.isDone(), // 0번 칸: 완료 여부 (체크박스)
					vo.getDoneDate(), // 1번 칸: 날짜
					vo.getContent(), // 2번 칸: 할 일 내용
					"삭제", // 3번 칸: 삭제 버튼
					vo.getDoneId() // 4번 칸 (숨겨짐): DB 고유 ID ★이게 무조건 맨 끝에 와야 함!
			}); // doneModel.addRow문 끝
		} // for문 끝
	} // loadDoneListFromDB() 끝

