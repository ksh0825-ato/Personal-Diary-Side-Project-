	private void handleDateClick(int day) {
		LocalDate sd = LocalDate.of(YEAR, currentMonth + 1, day);
		if (sd.isAfter(LocalDate.now())) {
			JOptionPane.showMessageDialog(this, "미래의 날짜에는 일기를 작성할 수 없습니다.", "날짜 제한 에러", 0);
			return;
		} // if문 끝
		openDiaryDetailOrForm(sd.toString());
	} // handleDateClick 끝

	public void openDiaryDetailOrForm(String dStr) {
		DiaryVO diary = diaryDAO.getDiaryByDate(currentUser.getUserId(), dStr);
		if (diary == null) {
			if (JOptionPane.showConfirmDialog(this, "해당 날짜에 작성된 일기가 없습니다. 새로 작성하시겠습니까?", "미작성 안내", 0) == 0)
				new DiaryFormDialog(this, diaryDAO, currentUser, dStr, null).setVisible(true);
		} else new DiaryFormDialog(this, diaryDAO, currentUser, dStr, diary).setVisible(true);
	} // openDiaryDetailOrForm 끝

	public static class SmartCellRenderer extends JTextArea implements TableCellRenderer {
		public SmartCellRenderer() {
			setLineWrap(true);
			setWrapStyleWord(true);
			setOpaque(true);
			setBorder(BorderFactory.createEmptyBorder(6, 8, 6, 8));
		} // public SmartCellRenderer() 끝

		@Override
		public Component getTableCellRendererComponent(JTable t, Object v, boolean s, boolean h, int r, int c) {
			setFont(t.getFont());
