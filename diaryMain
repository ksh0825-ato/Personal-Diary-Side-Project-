	private JPanel createLeftCalendarPanel() {
		JPanel panel = new JPanel(new BorderLayout(0, 10));
		panel.setOpaque(false);
		panel.setBorder(BorderFactory.createTitledBorder(BorderFactory.createLineBorder(COLOR_SECONDARY, 1), "월간 캘린더",
				0, 0, FONT_BOLD));
		JPanel ctrlPanel = new JPanel(new FlowLayout(FlowLayout.CENTER, 20, 5));
		ctrlPanel.setOpaque(false);
		JButton prevBtn = new JButton("◀"), nextBtn = new JButton("▶");
		monthLabel = new JLabel("", JLabel.CENTER);
		monthLabel.setFont(FONT_BOLD);
		prevBtn.addActionListener(e -> moveMonth(-1));
		nextBtn.addActionListener(e -> moveMonth(1));
		ctrlPanel.add(prevBtn);
		ctrlPanel.add(monthLabel);
		ctrlPanel.add(nextBtn);
		panel.add(ctrlPanel, BorderLayout.NORTH);

		calendarModel = new DefaultTableModel(new String[] { "일", "월", "화", "수", "목", "금", "토" }, 0) {
			@Override
			public boolean isCellEditable(int r, int c) {
				return false;
			} // isCellEditable 끝
		}; // DefaultTableModel 끝
		calendarTable = new JTable(calendarModel);
		calendarTable.setRowHeight(75);
		calendarTable.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
		calendarTable.setCellSelectionEnabled(true);
		calendarTable.getTableHeader().setReorderingAllowed(false);
		calendarTable.getTableHeader().setFont(FONT_BOLD);
		calendarTable.getTableHeader().setBackground(COLOR_SECONDARY);

		calendarTable.setDefaultRenderer(Object.class, new TableCellRenderer() {
			private final JTextPane tp = new JTextPane();
			{
				tp.setContentType("text/html");
				tp.setEditable(false);
				tp.setOpaque(true);
				tp.setMargin(new Insets(5, 4, 5, 4));
			} // JTextPane tp 끝

			@Override
			public Component getTableCellRendererComponent(JTable t, Object v, boolean s, boolean h, int r, int c) {
				if (v == null || v.toString().trim().isEmpty()) {
					tp.setText("");
					tp.setBackground(Color.WHITE);
					return tp;
				} // if문 1 끝
				
				String cleanNum = v.toString().replaceAll("<[^>]*>", "").trim().split(" ")[0];
				int day = Integer.parseInt(cleanNum.replaceAll("[^0-9]", ""));
				LocalDate cd = LocalDate.of(YEAR, currentMonth + 1, day), today = LocalDate.now();
				
				if (cd.isAfter(today)) {
					tp.setBackground(new Color(240, 240, 240));
					tp.setText(
							"<html><span style='font-family:sans-serif;font-size:11px;color:#B0B0B0;white-space:nowrap;'>"
									+ cleanNum + "</span></html>");
					return tp;
				} // if문 2 끝

				String tc = s ? "#FFFFFF" : (c == 0 ? "#FF0000" : (c == 6 ? "#0000FF" : "#194B8C"));
				List<String> mDates = diaryDAO.getMarkedDates(currentUser.getUserId());
				boolean isExist = mDates != null
						&& mDates.contains(String.format("%04d-%02d-%02d", YEAR, currentMonth + 1, day)),
						isToday = cd.equals(today);
				tp.setBackground(s ? t.getSelectionBackground()
						: (isToday ? COLOR_TODAY_PURPLE : (isExist ? COLOR_DIARY_EXIST : Color.WHITE)));
				String fw = (isExist || isToday) ? "bold" : "normal";
				String inner = v.toString().startsWith("<html>")
						? v.toString().replaceAll("<html>|</html>|<span[^>]*>|</span>", "")
						: String.valueOf(day);
				tp.setText(
						"<html><body style='margin:0;padding:0;'><span style='font-family:sans-serif;font-size:11px;white-space:nowrap;color:"
								+ tc + ";font-weight:" + fw + ";'>" + inner + "</span></body></html>");
				return tp;
			} // getTableCellRendererComponent override 끝
		}); // calendarTable.setDefaultRenderer 끝

		calendarTable.addMouseListener(new MouseAdapter() {
			@Override
			public void mouseClicked(MouseEvent e) {
				int r = calendarTable.getSelectedRow(), c = calendarTable.getSelectedColumn();
				if (r != -1 && c != -1 && calendarTable.getValueAt(r, c) != null
						&& !calendarTable.getValueAt(r, c).toString().trim().isEmpty())
					handleDateClick(Integer.parseInt(
							calendarTable.getValueAt(r, c).toString().replaceAll("<[^>]*>", "").trim().split(" ")[0]
									.replaceAll("[^0-9]", "")));
			} // mouseClicked 끝
		}); // calendarTable.addMouseListener 끝
		panel.add(new JScrollPane(calendarTable), BorderLayout.CENTER);
		return panel;
	} // createLeftCalendarPanel() 끝

	private JTabbedPane createRightManagementPanel() {
		JTabbedPane tp = new JTabbedPane();
		tp.setFont(FONT_BOLD);
		diaryListModel = new DefaultTableModel(new String[] { "번호", "날짜", "제목", "기분 배지", "최종 수정시각" }, 0) {
			@Override
			public boolean isCellEditable(int r, int c) {
				return false;
			} // isCellEditable 끝
		}; // diaryListModel = new DefaultTableModel 끝
		diaryListTable = new JTable(diaryListModel);
		setupTableStyle(diaryListTable, new int[] { 45, 90, 180, 85, 130 });
		diaryListTable.addMouseListener(new MouseAdapter() {
			@Override
			public void mouseClicked(MouseEvent e) {
				if (e.getClickCount() == 2 && diaryListTable.getSelectedRow() != -1
						&& !"-".equals(diaryListTable.getValueAt(diaryListTable.getSelectedRow(), 1)))
					openDiaryDetailOrForm((String) diaryListTable.getValueAt(diaryListTable.getSelectedRow(), 1));
			} // mouseClicked 끝
		}); // diaryListTable.addMouseListener 끝

		// [1] 모델 정의 (수정 버튼 제거, 총 5개 컬럼)
		doneModel = new DefaultTableModel(new String[] { "완료", "날짜", "할 일 내용", "삭제", "ID" }, 0) {
			@Override
			public Class<?> getColumnClass(int c) {
				return c == 0 ? Boolean.class : String.class;
			} // getColumnClass 끝

			@Override
			public boolean isCellEditable(int r, int c) {
				// 0:완료체크, 2:내용 텍스트, 3:삭제버튼
				return c == 0 || c == 2 || c == 3;
			} // isCellEditable 끝
		}; // doneModel = new DefaultTableModel 끝
		doneTable = new JTable(doneModel);

		// [2] 테이블 너비 세팅 (수정 버튼이 빠진 만큼 '할 일 내용'을 300으로 늘림)
		setupTableStyle(doneTable, new int[] { 45, 90, 300, 60, 0 });

		TableCellRenderer doneRen = (t, v, s, h, r, c) -> {
			JLabel l = new JLabel();
			l.setFont(t.getFont());
			l.setBorder(BorderFactory.createEmptyBorder(6, 8, 6, 8));
			Boolean isDone = (Boolean) t.getValueAt(r, 0);
			String text = v != null ? v.toString() : "";
			l.setText((isDone != null && isDone) ? "<html><s><font color='gray'>" + text + "</font></s></html>" : text);
			if (s) {
				l.setBackground(t.getSelectionBackground());
				l.setOpaque(true);
			} // if문 끝
			return l;
		}; // doneRen 끝

		// [3] 인덱스가 당겨졌으므로 이제 4번(ID)을 숨김 처리
		doneTable.getColumnModel().getColumn(4).setMinWidth(0);
		doneTable.getColumnModel().getColumn(4).setMaxWidth(0);
		doneTable.getColumnModel().getColumn(4).setWidth(0);

		// [4] 삭제 버튼 렌더러를 3번 컬럼에 매핑 (수정 버튼 렌더러는 삭제)
		doneTable.getColumnModel().getColumn(1).setCellRenderer(doneRen);
		doneTable.getColumnModel().getColumn(2).setCellRenderer(doneRen);
		doneTable.getColumnModel().getColumn(3).setCellRenderer(new ButtonCellEditorRenderer("삭제", false, this));
		doneTable.getColumnModel().getColumn(3).setCellEditor(new ButtonCellEditorRenderer("삭제", false, this));
		// 2. createRightManagementPanel() 안의 doneModel.addTableModelListener 수정
		doneModel.addTableModelListener(e -> {
			// 💡 [핵심 해결 방법] 행이 단순히 추가(INSERT)될 때는 무시하고, 수동으로 수정(UPDATE)될 때만 작동하게 만듭니다.
			if (e.getType() != javax.swing.event.TableModelEvent.UPDATE)
				return;

			doneTable.repaint();

			int row = e.getFirstRow();
			int col = e.getColumn();

			if (row >= 0 && row < doneModel.getRowCount()) {
				// 체크박스(0번 열)나 할 일 내용(2번 열)이 수정된 경우에만 DB 작업 수행
				if (col == 0 || col == 2) {
					Object idObj = doneModel.getValueAt(row, 4);

					// 💡 [안전 장치] 데이터가 없는 빈칸 처리용 "-" (String)인 경우 변환하지 않고 스킵하여 에러 방지
					if (idObj instanceof String)
						return;

					int doneId = (Integer) idObj; // 이제 안전하게 숫자로 변환 가능

					if (col == 0) {
						boolean isDone = (Boolean) doneModel.getValueAt(row, 0);
						diaryDAO.updateDoneStatus(doneId, isDone);
						refreshCalendar();
					} else if (col == 2) {
						String newContent = (String) doneModel.getValueAt(row, 2);
						diaryDAO.updateDoneContent(doneId, newContent);
					} // if-else if문 1-2 끝
				} // if문 1-1 끝
			} // if문 1 끝
		}); // doneModel.addTableModelListener 끝

		JPanel doneTabPanel = new JPanel(new BorderLayout());
		JLabel guideLabel = new JLabel("💡 팁: '할 일 내용' 칸을 더블클릭하면 텍스트를 바로 수정할 수 있습니다.", JLabel.LEFT);
		guideLabel.setFont(FONT_SMALL);
		guideLabel.setForeground(Color.GRAY);
		guideLabel.setBorder(BorderFactory.createEmptyBorder(8, 10, 8, 10));

		doneTabPanel.add(guideLabel, BorderLayout.NORTH);
		doneTabPanel.add(new JScrollPane(doneTable), BorderLayout.CENTER);

		tp.addTab("일기장 타임라인 목록", new JScrollPane(diaryListTable));
		tp.addTab("종합 Done-List 모아보기", doneTabPanel); // 래핑된 패널로 추가

		return tp;
	} // createRightManagementPanel() 끝

	private void setupTableStyle(JTable t, int[] w) {
		t.setFont(FONT_MAIN);
		t.setRowHeight(42);
		t.getTableHeader().setReorderingAllowed(false);
		t.getTableHeader().setBackground(COLOR_BG_LIGHT);
		t.getTableHeader().setFont(FONT_BOLD);
		SmartCellRenderer cr = new SmartCellRenderer();
		for (int i = 0; i < t.getColumnCount(); i++) {
			t.getColumnModel().getColumn(i).setPreferredWidth(w[i]);
			if (i > 0 && t.getColumnModel().getColumn(i).getCellRenderer() == null)
				t.getColumnModel().getColumn(i).setCellRenderer(cr);
		} // for문 끝
	} // setupTableStyle 끝

	private void moveMonth(int a) {
		if (currentMonth + a < 0 || currentMonth + a > 11) {
			JOptionPane.showMessageDialog(this, "2026년도 내에서만 이동할 수 있습니다.", "안내", 1);
			return;
		} // if문 끝
		currentMonth += a;
		refreshCalendar();
	} // moveMonth 끝

	public void refreshDiaryList() {
		diaryListModel.setRowCount(0);
		List<DiaryVO> list = diaryDAO.getDiaryList(currentUser.getUserId());
		if (list == null || list.isEmpty()) {
			diaryListModel.addRow(new Object[] { "-", "-", "", "-", "-" });
			return;
		} // if문 끝
		list.sort(Comparator.comparing(DiaryVO::getDiaryDate));
		int rn = 1;
		for (DiaryVO d : list)
			diaryListModel
					.addRow(new Object[] { rn++, d.getDiaryDate(), d.getTitle(),
							(d.getMoodId() >= 1 && d.getMoodId() < MOOD_ITEMS.length) ? MOOD_ITEMS[d.getMoodId()]
									: MOOD_ITEMS[0],
							d.getUpdatedAt() != null ? d.getUpdatedAt().replace(" ", "\n") : "기록없음" });
		// d.getUpdatedAt()이 null인 상태
	} // refreshDiaryList() 끝

	public void refreshCalendar() {
		calendarModel.setRowCount(0);
		monthLabel.setText(YEAR + "년 " + (currentMonth + 1) + "월");
		List<String> mDates = diaryDAO.getMarkedDates(currentUser.getUserId());
		Calendar cal = Calendar.getInstance();
		cal.set(YEAR, currentMonth, 1);
		int sDay = cal.get(Calendar.DAY_OF_WEEK) - 1, mDay = cal.getActualMaximum(Calendar.DAY_OF_MONTH), cIdx = sDay;
		Object[] row = new Object[7];
		
		for (int i = 0; i < sDay; i++)
			row[i] = "";
		
		for (int d = 1; d <= mDay; d++) {
			String ds = String.format("%04d-%02d-%02d", YEAR, currentMonth + 1, d);
			int dc = getDoneCountByDate(ds);
			String db = dc > 0 ? " <font color='#4A6999'><u>+" + dc + "</u></font>" : "", mi = "";
			if (mDates != null && mDates.contains(ds)) {
				DiaryVO dv = diaryDAO.getDiaryByDate(currentUser.getUserId(), ds);
				if (dv != null && dv.getMoodId() >= 1 && dv.getMoodId() < MOOD_ITEMS.length)
					mi = " " + MOOD_ITEMS[dv.getMoodId()].split(" ")[0];
			} // if문 1 끝
			row[cIdx++] = (!mi.isEmpty() || !db.isEmpty())
					? "<html><span style='white-space: nowrap;'>" + d + mi + db + "</span></html>"
					: String.valueOf(d);
			if (cIdx == 7) {
				calendarModel.addRow(row);
				row = new Object[7];
				cIdx = 0;
			} // if문 2 끝
		} // for문 끝
		if (cIdx > 0) {
			for (int i = cIdx; i < 7; i++)
				row[i] = "";
			calendarModel.addRow(row);
		} // if문 3 끝
	} // refreshCalendar() 끝

	private int getDoneCountByDate(String dStr) {
		if (doneModel == null)
			return 0;
		int c = 0;
		for (int i = 0; i < doneModel.getRowCount(); i++)
			if (dStr.equals(doneModel.getValueAt(i, 1))
					&& (doneModel.getValueAt(i, 0) == null || !(Boolean) doneModel.getValueAt(i, 0)))
				c++;
		return c;
	} // getDoneCountByDate 끝

	@SuppressWarnings("unchecked")
	public void refreshDoneList() {
		if (doneModel == null)
			return;
		List<Vector> vRows = new ArrayList<>();
		for (Vector r : doneModel.getDataVector())
			if (r.size() > 1 && !"-".equals(r.get(1)))
				vRows.add(r);
		vRows.sort((r1, r2) -> ((String) r1.get(1)).compareTo((String) r2.get(1)));
		doneModel.setRowCount(0);
		if (vRows.isEmpty())
			doneModel.addRow(new Object[] { false, "-", "기록된 할 일이 없습니다.", "삭제", "-" });
		else
			for (Vector r : vRows)
				doneModel.addRow(r);
	} // refreshDoneList() 끝

