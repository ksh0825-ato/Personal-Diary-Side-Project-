		setSize(1250, 750);
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		setLocationRelativeTo(null);

		initUI();
		loadDoneListFromDB(); // 1. DB에서 할 일 목록을 먼저 가져와 모델을 채웁니다.
		refreshCalendar(); // 2. 채워진 데이터를 바탕으로 캘린더를 그립니다 (+n 표시).
		refreshDiaryList(); // 3. 일기 목록을 갱신합니다.
	} // DiaryMain 끝

