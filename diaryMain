	public static class ButtonCellEditorRenderer extends AbstractCellEditor
			implements TableCellRenderer, TableCellEditor {
		private final JButton btn;
		private final String lbl;
		private final boolean isEdit;
		private final DiaryMain mf;
		private int cRow;

		public ButtonCellEditorRenderer(String l, boolean ie, DiaryMain m) {
			lbl = l;
			isEdit = ie;
			mf = m;
			btn = new JButton(l);
			btn.setOpaque(true);
			btn.setFont(FONT_SMALL);

			btn.addActionListener(e -> {
				int targetRow = cRow; // 클릭한 행 번호 안전하게 고정
				fireEditingStopped(); // 편집 종료

				// 유효하지 않은 행이거나 데이터가 없는 빈 칸("-")이면 무시
				if (targetRow < 0 || targetRow >= mf.doneModel.getRowCount())
					return;
				Object idObj = mf.doneModel.getValueAt(targetRow, 4);
				if (idObj instanceof String && "-".equals(idObj))
					return;

				if (!isEdit && JOptionPane.showConfirmDialog(mf, "선택하신 Done 항목을 목록에서 삭제하시겠습니까?", "항목 삭제", 0) == 0) {

					int doneId = -1;

					// 💡 [핵심] 4번 칸의 ID가 숫자든 문자열이든 무조건 추출해 냅니다.
					if (idObj instanceof Integer) {
						doneId = (Integer) idObj;
					} else if (idObj != null) {
						try {
							doneId = Integer.parseInt(idObj.toString().trim());
						} catch (NumberFormatException ex) {
							System.out.println("🚨 변환 실패 - 잘못된 ID 값: " + idObj);
						}
					} // try-catch 끝

					// 추출한 ID가 정상적이면 무조건 DB에서 지워버립니다.
					if (doneId != -1) {
						mf.diaryDAO.deleteDone(doneId);
					} // if문 1-1 끝

					// 💡 화면만 어설프게 지우는 게 아니라, DB에서 최신 상태를 완전히 새로 불러와서 덮어씌웁니다.
					mf.loadDoneListFromDB();
					mf.refreshCalendar();
				} // if문 1 끝
			}); // btn.addActionListener 끝
		} // public ButtonCellEditorRenderer 끝

		@Override
		public Component getTableCellRendererComponent(JTable t, Object v, boolean s, boolean h, int r, int c) {
			return btn;
		}

		@Override
		public Component getTableCellEditorComponent(JTable t, Object v, boolean s, int r, int c) {
			cRow = r;
			return btn;
		}

		@Override
		public Object getCellEditorValue() {
			return lbl;
		}
	} // ButtonCellEditorRenderer 끝

